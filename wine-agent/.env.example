# Wine Agent — example environment configuration.
#
# Copy to `.env` for local use (`.env` is gitignored and MUST NOT be committed).
# This file holds NO real secrets — only placeholders and non-sensitive knobs.
# The app currently requires no secrets at all; the placeholders below are here
# so future secrets have a documented, env-only home (see SECURITY.md).

# --- Backends (non-sensitive) ---
# fake = deterministic offline default; ollama = local models.
WINE_LLM_BACKEND=fake
WINE_EMBED_BACKEND=fake
OLLAMA_BASE_URL=http://localhost:11434
WINE_LLM_MODEL=qwen2.5:7b-instruct
WINE_EMBED_MODEL=bge-m3

# --- Retrieval / session knobs (non-sensitive) ---
WINE_TOP_K=6
WINE_MAX_MSG_CHARS=2000
WINE_HISTORY_TURNS=4
WINE_SESSION_TTL=1800
# WINE_SNAPSHOT_DIR=/path/to/published/snapshot

# --- Secrets (leave UNSET unless the corresponding feature is enabled) ---
# These do not exist yet. When added, they are read via config.require_secret()
# and must be provided by the environment / secret store — never written here
# with a real value, never committed.
#
# WINE_SITE_TOKEN=            # public widget token verified server-side (future)
# WINE_LLM_API_KEY=           # only if switching to a hosted LLM endpoint (future)
